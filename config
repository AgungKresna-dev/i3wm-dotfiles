# ==============================================================================
# i3wm CONFIGURATION FILE
# Optimized for Keyboard-Driven Productivity & Clean Portfolios
# Theme: Dracula (Official Spec) with i3-gaps enabled
# Reference: https://i3wm.org/docs/userguide.html#configuring
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Variables & Modifiers
# ------------------------------------------------------------------------------
# Set Modifier Key (Mod4 = Windows Key)
set $mod Mod4

# Applications & Launchers
set $terminal   kitty
set $launcher1  dmenu_run -fn 'Lilex Nerd Font Mono-10' -nb '#282a36' -nf '#f8f8f2' -sb '#bd93f9' -sf '#282a36'
set $launcher2  rofi -show drun -theme ~/.config/rofi/config.rasi

# Dracula Color Palette
set $dracula-bg           #282a36
set $dracula-curnt-line   #44475a
set $dracula-fg           #f8f8f2
set $dracula-comment      #6272a4
set $dracula-cyan         #8be9fd
set $dracula-green        #50fa7b
set $dracula-orange       #ffb86c
set $dracula-pink         #ff79c6
set $dracula-purple       #bd93f9
set $dracula-red          #ff5555
set $dracula-yellow       #f1fa8c

# ------------------------------------------------------------------------------
# 2. Fonts & Visuals (Including i3-gaps Settings)
# ------------------------------------------------------------------------------
# Font for window titles and bar
font pango:Lilex Nerd Font 10

# Thin borders for a modern look
default_border pixel 3
default_floating_border normal 3
hide_edge_borders smart

# --- i3-gaps Configuration ---
# Inner gaps: Space between windows
gaps inner 25

# Outer gaps: Space between windows and screen edges
gaps outer -5

# Only show borders if there is more than one window on a workspace
#smart_borders on
# ------------------------------

# Window Colors (Dracula Theme Spec)
# class                 border                  background              text                indicator       child_border
client.focused          $dracula-purple         $dracula-purple         $dracula-bg         $dracula-pink   $dracula-purple
client.focused_inactive $dracula-curnt-line     $dracula-curnt-line     $dracula-fg         $dracula-purple $dracula-curnt-line
client.unfocused        $dracula-bg             $dracula-bg             $dracula-comment    $dracula-purple $dracula-bg
client.urgent           $dracula-red            $dracula-red            $dracula-fg         $dracula-purple $dracula-red

# ------------------------------------------------------------------------------
# 3. Keybindings: Core Operations
# ------------------------------------------------------------------------------
# Start terminal
bindsym $mod+Return exec $terminal

# Special Floating Terminal (Launches with a unique X11 window class)
bindsym $mod+Shift+Return exec --no-startup-id kitty --class kitty-floating

# Kill focused window
bindsym $mod+Shift+q kill

# Launchers (Mod+d for Rofi, Mod+Shift+d for Dmenu)
bindsym $mod+d exec --no-startup-id $launcher2
bindsym $mod+Shift+d exec --no-startup-id $launcher1

# Reload the configuration file
bindsym $mod+Shift+c reload

# Restart i3 inplace (preserves your layout/session)
bindsym $mod+Shift+r restart

# Exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"

# Screen Brightness Controls (Requires brightnessctl or light)
bindsym XF86MonBrightnessUp exec --no-startup-id "brightnessctl set +5% && dunstify -a 'System' -h string:x-dunst-stack-tag:brightness -h int:value:$(brightnessctl -m | cut -d, -f4 | tr -d '%') '󰖨 Brightness' -i notification-display-brightness"
bindsym XF86MonBrightnessDown exec --no-startup-id "brightnessctl set 5%- && dunstify -a 'System' -h string:x-dunst-stack-tag:brightness -h int:value:$(brightnessctl -m | cut -d, -f4 | tr -d '%') '󰖨 Brightness' -i notification-display-brightness"

# Audio Volume Controls (Native Pipewire / WirePlumber)
# Raise volume (capped at 100%)
bindsym XF86AudioRaiseVolume exec --no-startup-id "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+ && dunstify -a 'System' -h string:x-dunst-stack-tag:volume -h int:value:$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}') '󰕾 Audio Volume'"

# Lower volume
bindsym XF86AudioLowerVolume exec --no-startup-id "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && dunstify -a 'System' -h string:x-dunst-stack-tag:volume -h int:value:$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2*100}') '󰕾 Audio Volume'"

# Toggle mute
bindsym XF86AudioMute exec --no-startup-id "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle && dunstify -a 'System' -h string:x-dunst-stack-tag:volume '󰝟 Audio Mute Toggle'"

# Microphone Volume Controls (Native Pipewire / WirePlumber)
# Raise microphone volume (capped at 100%)
bindsym $mod+XF86AudioRaiseVolume exec --no-startup-id "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SOURCE@ 5%+ && dunstify -a 'System' -h string:x-dunst-stack-tag:mic -h int:value:$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | awk '{print $2*100}') '󰍬 Mic Volume'"

# Lower microphone volume
bindsym $mod+XF86AudioLowerVolume exec --no-startup-id "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%- && dunstify -a 'System' -h string:x-dunst-stack-tag:mic -h int:value:$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | awk '{print $2*100}') '󰍬 Mic Volume'"

# Toggle microphone mute
bindsym $mod+XF86AudioMute exec --no-startup-id "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle && dunstify -a 'System' -h string:x-dunst-stack-tag:mic '󰍭 Mic Mute Toggle'"

# Manual lock trigger using Mod+Shift+x with Dark+Blur effects and instant screen-off
bindsym $mod+Shift+x exec --no-startup-id betterlockscreen -l dimblur --off 5

# ------------------------------------------------------------------------------
# 4. Keybindings: Navigation & Layouts
# ------------------------------------------------------------------------------

# Mouse Bindings
# Mod+Left Click: Drag floating windows to move them (Default i3 behavior)
# Mod+Right Click: Drag to resize windows from any edge (Default i3 behavior)
floating_modifier $mod

# Mod+Middle Click: Toggle window state between floating and tiling seamlessly
# bindsym --whole-window $mod+button2 floating toggle
bindsym --whole-window $mod+button2 kill

# Change focus (Vim-style navigation)
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Toggle split direction (Horizontal <-> Vertical) using a single keybinding
bindsym $mod+q split toggle

# Enter fullscreen mode
bindsym $mod+f fullscreen toggle

# Change container layout
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# Toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# Change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# ------------------------------------------------------------------------------
# 5. Workspaces Configuration
# ------------------------------------------------------------------------------
# Define Workspace Names with Nerd Font Glyphs
set $ws1 "1:󰆍 "
set $ws2 "2:󰖟 "
set $ws3 "3:󰲋 "
set $ws4 "4:󰭹 "
set $ws5 "5:󰝚 "

# Switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5

# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5

# Cycle through workspaces sequentially (Left / Right)
bindsym $mod+Prior workspace prev
bindsym $mod+Next workspace next

# Toggle back and forth between the two most recently focused workspaces
bindsym $mod+Tab workspace back_and_forth

# ------------------------------------------------------------------------------
# 6. Resizing Mode
# ------------------------------------------------------------------------------
mode "Resize" {
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym j resize grow height 5 px or 5 ppt
        bindsym k resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt

        # Back to normal mode
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
bindsym $mod+r mode "Resize"

# ------------------------------------------------------------------------------
# 7. Status Bar Configuration (Implementing Chapter 5 Opsi Lengkap)
# ------------------------------------------------------------------------------
bar {
        # 5.1 i3status command invocation
        status_command i3status --config ~/.config/i3/i3status/config
        
        # 5.2 Bar positioning (top or bottom)
        position top
        
        # 5.3 Display mode (dock, hide, or invisible)
        mode dock
        
        # 5.4 Modifier key to toggle bar visibility when hidden (e.g., Mod4)
        modifier Mod4
        
        # 5.5 Monitor/Output selection (uncomment to bind to specific monitors)
        # output primary
        
        # 5.6 Workspace interactive buttons toggle
        workspace_buttons yes
        
        # 5.7 Remove number prefixes from workspace names
        strip_workspace_numbers yes
        strip_workspace_name yes
        
        # 5.8 Binding mode indicator toggle on the bar
        binding_mode_indicator yes
        
        # 5.9 Font configuration and height/vertical padding adjustments
        font pango:Lilex Nerd Font 11
        workspace_min_width 50
        padding 3px 0
        tray_padding 7px

        # 5.10 Disable clicking on workspace buttons
        bindsym button1 nop
        bindsym button2 nop
        bindsym button3 nop
        bindsym button4 nop
        bindsym button5 nop
        bindsym button6 nop
        bindsym button7 nop

        # 5.11 Detailed color palette definitions (Dracula Spec Integration)
        colors {
                background $dracula-bg
                statusline $dracula-fg
                separator  $dracula-comment

                # class            border                 background             text
                focused_workspace  $dracula-purple        $dracula-purple        $dracula-bg
                active_workspace   $dracula-curnt-line    $dracula-curnt-line    $dracula-fg
                inactive_workspace $dracula-bg            $dracula-bg            $dracula-comment
                urgent_workspace   $dracula-red           $dracula-red           $dracula-fg
                binding_mode       $dracula-red           $dracula-red           $dracula-bg
        }
}

# ------------------------------------------------------------------------------
# 8. Autostart Applications
# ------------------------------------------------------------------------------
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id nm-applet
exec --no-startup-id dunst
exec --no-startup-id picom -b
exec --no-startup-id feh --bg-fill ~/.config/i3/wallpapers/linux-arch-dark.jpg

# Power Management: Monitor battery with upower and alert via notifications
exec_always --no-startup-id poweralertd

# Idle Management: xidlehook configuration
# 300s (5m)  : Screen off
# 900s (15m) : Lock screen
# 1800s (30m): Suspend system
exec_always --no-startup-id xidlehook \
  --not-when-fullscreen \
  --not-when-audio \
  --timer 300 'xset dpms force off' '' \
  --timer 600 'betterlockscreen -l dimblur --off 1' '' \
  --timer 900 'systemctl suspend' ''

# ------------------------------------------------------------------------------
# 9. Window Rules & Custom Target Routings
# ------------------------------------------------------------------------------
# Layout Enforcers (Targeting entire workspaces directly using criteria)
for_window [workspace=$ws1] layout default
for_window [workspace=$ws2] layout tabbed
for_window [workspace=$ws3] layout tabbed

# Automatically format the dedicated floating terminal with 50% width and 50% height
for_window [class="kitty-floating"] floating enable, resize set 50 ppt 50 ppt, move position center

# Force Places window instances (Bookmarks, History, Library managers) into floating mode
for_window [class="(?i)firefox" instance="^Places$"] floating enable, resize set 50 ppt 50 ppt, move position center
for_window [class="^zen$" instance="^Places$"] floating enable, resize set 50 ppt 50 ppt, move position center

# Force floating for Firefox windows with dynamic titles starting with "Torrents"
for_window [class="(?i)firefox" instance="^Navigator$" title="^Torrents.*"] floating enable, resize set 33 ppt 50 ppt, move position center

# Force floating for Zen Browser windows with dynamic titles starting with "Torrents"
for_window [class="^zen$" instance="^Navigator$" title="^Torrents.*"] floating enable, resize set 33 ppt 50 ppt, move position center

# Force Firefox Picture-in-Picture window into floating, precise size, and bottom-right position
for_window [class="(?i)firefox" title="^Picture-in-Picture$"] floating enable, resize set 25 ppt 25 ppt, move window to position 1420 px 790 px, sticky enable
no_focus [class="(?i)firefox" title="^Picture-in-Picture$"]

# Force Zen Browser Picture-in-Picture window into floating, precise size, and bottom-right position
for_window [class="^zen$" title="^Picture-in-Picture$"] floating enable, resize set 25 ppt 25 ppt, move window to position 1420 px 790 px, sticky enable
no_focus [class="^zen$" title="^Picture-in-Picture$"]

# MPV Standard Mode: Treat like Picture-in-Picture (Floating, bottom-right, no focus)
for_window [class="^mpv$" window_role="^mpv$"] floating enable, resize set 25 ppt 25 ppt, move window to position 1420 px 790 px, sticky enable
no_focus [class="^mpv$" window_role="^mpv$"]

# MPV Fullscreen Mode: Force full override and automatically grab input focus
for_window [class="^mpv$" window_role="^mpv-fullscreen$"] floating disable, focus

# XDM Main Dashboard View Layout Constraints
for_window [class="^Xdm-app$" title="^Xtreme Download Manager$"] floating enable, resize set 75 ppt 75 ppt, move position center

# XDM Intercept Target for New Download Popup Trigger Events
for_window [class="^Xdm-app$" title="^New Download$"] floating enable, resize set 30 ppt 15 ppt, move position center

# XDM Intercept Target for Settings Window Panel Configuration
for_window [class="^Xdm-app$" title="^Settings$"] floating enable, resize set 50 ppt 50 ppt, move position center

# WS1: Core Tiling Terminal Routing (Bypasses kitty-floating class)
assign [class="^kitty$"] $ws1

# WS2: Modern Web Browsers Routing
assign [class="^Google-chrome$"] $ws2
assign [class="^firefox$"] $ws2
assign [class="^zen$"] $ws2

# WS3: File Managers Routing
assign [class="^Pcmanfm$"] $ws3
assign [class="^pcmanfm-qt$"] $ws3
